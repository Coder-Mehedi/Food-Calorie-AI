# Environment Variables

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=food_calorie_ai

# JWT
JWT_SECRET=change-this-to-a-secure-random-string

# AI Provider: "gemini" (default, free) or "openrouter" (free models available)
AI_PROVIDER=gemini
AI_API_KEY=your-api-key-here

# Gemini: get free key at https://aistudio.google.com/apikey
# OpenRouter: get free key at https://openrouter.ai/keys

# App
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:19006,http://localhost:8081
UPLOAD_DIR=./uploads
