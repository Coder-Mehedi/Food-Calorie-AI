{
  "expo": {
    "name": "Calorie AI",
    "slug": "calorie-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#4CAF50"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stackoverclocker.calorieai",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs camera access to scan food images",
        "NSPhotoLibraryUsageDescription": "This app needs photo library access to upload food images",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4CAF50"
      },
      "package": "com.stackoverclocker.calorieai",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos for food scanning.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera for food scanning."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "f3c1756e-3e09-4b73-abbb-ecbf4d059800"
      }
    }
  }
}
